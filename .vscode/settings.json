{
	"editor.defaultFormatter": "nickfode.latex-formatter",
	"editor.wordWrap": "on",
	"explorer.excludeGitIgnore": true,
	"files.associations": {
		".latexmkrc": "perl"
	},
	"files.autoSave": "afterDelay",
	"latex-utilities.message.update.show": false,
	"latex-workshop.intellisense.package.unusual": true,
	"latex-workshop.latex.autoBuild.run": "onSave",
	"latex-workshop.latex.build.rootfileInStatus": true,
	"latex-workshop.latex.outDir": "build",
	"latex-workshop.latex.search.rootFiles.include": [
		"draft.tex"
	],
	"latex-workshop.linting.run": "onType",
	"latex-workshop.synctex.afterBuild.enabled": true,
	"ltex.java.path": "/usr",
	"ltex.language": "en-US",
	"latex-workshop.latex.recipe.default": "latexmk (latexmkrc)",
	"latex-workshop.message.error.show": false
}
